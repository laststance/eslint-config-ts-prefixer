  "dependencies": {
    "eslint": "^10.4.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.61.0"
  },
  "devDependencies": {
